<!DOCTYPE html>
<html lang="en">

<head>
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
    <link rel="stylesheet" href="/assets/style.css">
    <!--Import Libraries-->
    <script src="/libraries/notyf.min.js"></script>
    <script src="/libraries/dropzone-min.js"></script>
    <script src="/libraries/popper.min.js"></script>
    <script src="/libraries/tippy-bundle.iife.min.js"></script>
    <script src="/libraries/purify.min.js"></script>
    <script src="/libraries/syncscroll.min.js "></script>
    <script defer src="/assets/index.js"></script>
</head>

<body onload="leftOff(true); inputVisible(); createList()">
    <span id="pageNumber" data-pos="up" onclick="showInd(this);"></span>
    <div id="nav" onclick = "hideInd();">
        <span id="icon1" onclick="notePost();">💾</span>
        <span id="icon2" onclick="newP();">📖</span>
        <span id="icon3" onclick="del();">🗑️</span>
        <span id="icon4">
            <label for="getFile1">🖼️</label>
            <form id="myForm">
                <input type="file" name="avatar" id="getFile1" style='display:none' onchange="insertImage();">
            </form>
        </span>
        <span id="icon5" onclick="toggle();">👁️</span>
        <span id="icon6" onclick="addPage(true, 1); updateNotes();">◀️</span>
        <span id="icon7" onclick="addPage(false,1); updateNotes();">▶️</span>
        <span id="icon8"><span id="wikipedia">🧠</span></span>
        <a id="sync" tabindex="-1" href='/home'></a>
    </div>
    <div id="tab" onclick="showList()"></div>
    <div id="list"></div>
    <div id = "notesArea" onclick = "hideList(); hideInd();">
        <div id="notes" class="syncscroll" name="myElements" onclick="hideInd(); hideList(); wikiSearch(event);"></div>
        <textarea readonly id="in" tabindex="0" class="syncscroll" name="myElements" spellcheck="true" onclick="hideInd(); hideList();" placeholder="Type your notes here"></textarea>
    </div>
    <div id="moneyAnimation"></div>
    <!-- Discord webhook loaded dynamically -->
    <span id="discord_webhook"><%= data.hook %></span>
    <span id = "bookSave"><%= data.book %></span>
</body>

</html>