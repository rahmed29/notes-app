<!DOCTYPE html>
<html lang="en">
<head>
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
    <link rel="stylesheet" href="/assets/style.css">
    <link rel="manifest" href="/manifest.json">
    <!--Import JS-->
    <script src="/libraries/notyf.min.js"></script>
    <script src="/libraries/dropzone-min.js"></script>
    <script src="/libraries/popper.min.js"></script>
    <script src="/libraries/tippy-bundle.iife.min.js"></script>
    <script src="/libraries/purify.min.js"></script>
    <script src="/libraries/syncscroll.min.js"></script>
    <script defer src="/assets/index.js"></script>
    <script defer src="/assets/listeners.js"></script>
</head>
<body>
    <span id="pageNumber" data-pos="up"></span>
    <div id = "mobileSync"></div>
    <div id = "navContainer">
        <div id = "mobileMenu">
            ...
        </div>
        <div id="nav">
            <span id="icon1">💾</span>
            <span id="icon2">📖</span>
            <span id="icon3">🗑️</span>
            <span id="icon4">
                <label for="getFile1" id = "labelForImage">🖼️</label>
                <form id="myForm">
                    <input type="file" name="avatar" id="getFile1" style='display:none'>
                </form>
            </span>
            <span id="icon5">👁️</span>
            <span id="icon6">◀️</span>
            <span id="icon7">▶️</span>
            <span id="icon8"><span id="wikipedia">🧠</span></span>
            <a id="sync" tabindex="-1" href = "/home"></a>
        </div>
    </div>
    <div id="tab"></div>
    <div id="list"></div>
    <div id = "notesArea">
        <div id="notes" class="syncscroll" name="myElements"></div>
        <textarea readonly id="in" tabindex="0" class="syncscroll" name="myElements" spellcheck="true" placeholder="Type your notes here"></textarea>
    </div>
    <div id="moneyAnimation"></div>
    <span id="discord_webhook"><%= data.hook %></span>
    <span id = "bookSave"><%= data.book %></span>
</body>
</html>