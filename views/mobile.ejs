<!DOCTYPE html>
<html lang="en">
<head>
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
    <link rel="stylesheet" href="/assets/mobile/style.css">
    <link rel="manifest" href="/manifest.json">
    <link rel="preconnect" href="https://rsms.me/">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <!--Import JS-->
    <script src="https://emoji.fluent-cdn.com/latest/fluentemoji.min.js" crossorigin="anonymous"></script>
    <script src = "/libraries/diff.min.js"></script>
    <script src = "/libraries/dragscroll.min.js"></script>
    <script src="/libraries/notyf.min.js"></script>
    <script src="/libraries/dropzone-min.js"></script>
    <script src="/libraries/popper.min.js"></script>
    <script src="/libraries/tippy-bundle.iife.min.js"></script>
    <script src="/libraries/purify.min.js"></script>
    <script defer src="/assets/mobile/index.js"></script>
    <script defer src="/assets/mobile/listeners.js"></script>
</head>
<body>
    <pre id = "currDiff" class="dragscroll"></pre>
    <span id="pageNumber" data-pos="up"></span>
    <div id = "mobileSyncContainer">
        <div id = "mobileSync"></div>
    </div>
    <div id = "mobileMenu">
        ...
    </div>
    <div id="nav">
        <span id="icon1">&#128190;</span>
        <span id="icon2">&#128214;</span>
        <span id="icon3">&#128465;&#65039;</span>
        <span id="icon4">
            <label for="getFile1" id = "labelForImage">&#x1f5bc;&#xfe0f;</label>
            <form id="myForm">
                <input type="file" name="avatar" id="getFile1" style='display:none'>
            </form>
        </span>
        <span id="icon5">&#128065;&#65039;</span>
        <span id="icon6">&#9664;&#65039;</span>
        <span id="icon7">&#9654;&#65039;</span>
        <span id="icon8"><span id="wikipedia">&#129504;</span></span>
        <span id="sync" tabindex="-1"></span>
    </div>
    <div id="tab"></div>
    <div id = "container">
        <div id="list"></div>
        <div id = "notesArea">
            <div id="notes" name="myElements"></div>
            <textarea readonly id="in" tabindex="0" name="myElements" spellcheck="true" placeholder="Type your notes here"></textarea>       
        </div>
    </div>
    <div id="moneyAnimation"></div>
    <span id = "bookSave"><%= data.book %></span>
</body>
</html>