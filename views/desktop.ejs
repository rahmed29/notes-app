<!DOCTYPE html>
<html lang="en">
  <head>
    <title>notes.ryaan.win/</title>
    <meta http-equiv="content-type" content="text/html; charset=UTF-8" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <link rel="icon" type="image/x-icon" href="/assets/vite.svg" />
    <!-- Inter font -->
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <!---->

    <!-- Load self hosted libraries -->
    <script src="/assets/diff.min.js"></script>
    <script src="/assets/syncscroll.min.js"></script>
    <!---->

    <!-- index.js -->
    <script type="module" crossorigin src="/assets/index-DNqGcpRu.js"></script>
    <link rel="stylesheet" crossorigin href="/assets/index-BM8xcXYN.css">
  </head>
  <body>
    <div id="wikipediaBrainAnimation"></div>

    <div id="stickyNotes" class="gone" data-pos="hidden" data-text="">
      <textarea id="stickyNotesTextArea" autocomplete="false"></textarea>
      <span id="stickyNotesEmoji">
        <img
          class="emoji"
          src="data:image/png;base64,"
        />
      </span>
    </div>

    <div id="openCalendar" data-pos="hidden" data-text="">
      <span id="openCalendarEmoji">
        <img class="emoji" src="/assets/calendar_3d-DtXRyo0x.png" />
      </span>
    </div>

    <div id="toolBar">
      <div id="icons">
        <span id="icon1">
          <img
            class="emoji"
            src="data:image/png;base64,"
          />
        </span>
        <span id="icon2">
          <img
            class="emoji"
            src="data:image/png;base64,"
          />
        </span>
        <span id="icon3">
          <img class="emoji" src="/assets/1f5d1-fe0f-Cfbwrs58.png" />
        </span>
        <span id="icon4">
          <label for="getFile1" id="labelForImage">
            <img class="emoji" src="/assets/1f5bc-fe0f-BciTvtE3.png" />
          </label>
          <form id="myForm">
            <input
              id="getFile1"
              type="file"
              name="avatar"
              style="display: none"
            />
          </form>
        </span>
        <span id="icon5">
          <img class="emoji" src="/assets/1f441-fe0f-CGPyzAi_.png" />
        </span>
        <span id="icon6">
          <img
            class="emoji"
            src="data:image/png;base64,"
          />
        </span>
        <span id="icon7">
          <img
            class="emoji"
            src="data:image/png;base64,"
          />
        </span>
        <span id="icon8" data-enabled="true">
          <img
            class="emoji"
            src="data:image/png;base64,"
          />
        </span>
        <span id="areNotesSavedIcon">
          <img
            class="emoji"
            src="data:image/png;base64,"
          />
        </span>
      </div>
    </div>

    <div id="bottomLeftGeneralInfo">
      <span id="generalInfoPageNumber"></span>
      <span id="generalInfoViewMode"></span>
      <span id="letterCount">00000</span>
      <span id="wordCount">00000</span>
    </div>

    <div id="mainContainer">
      <div id="leftMostSideBar">
        <div id="topLeftPageNumbers"></div>
        <div class="whereTo" id="morePages" data-vis="hidden">...</div>
        <div class="whereTo" id="newPage">+</div>
        <div id="sideBarRetractList"></div>
        <a id="goHome" class="whereTo">/</a>
      </div>
      <div id="listOfBooks" data-pos="shown">
        <div id="searchItem">
          <input placeholder="Search..." id="searchBar" />
        </div>
        <div id="listContainer"></div>
        <div class="itemUpload">
          <div id="yourUploads" class="folderName">Your Uploads</div>
          <ul id="uploads"></ul>
        </div>
      </div>
      <div id="border"></div>
      <div id="workspace">
        <div id="tabs"></div>
        <div id="notesAreaContainer">
          <div id="notesTextArea" class="syncscroll" name="myElements" data-vim="false">
            <pre id="editor"></pre>
          </div>
          <div id="notesPreviewArea" class="syncscroll" name="myElements"></div>
        </div>
      </div>
    </div>
    <script
      src="/assets/src-min/ace.js"
      type="text/javascript"
      charset="utf-8"
    ></script>
  </body>
</html>
